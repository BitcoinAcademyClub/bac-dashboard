    {q:"O que significa uma transação com 0 confirmações?",opts:["A transação falhou","Ainda está no mempool — não está na blockchain","Foi confirmada instantaneamente","Tem fee zero"],a:1},
    {q:"Quanto tempo demoram 6 confirmações em média?",opts:["6 minutos","10 minutos","~1 hora (6 x 10 min)","6 horas"],a:2},
