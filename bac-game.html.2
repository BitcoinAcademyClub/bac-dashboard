<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BAC Game · Aprende Bitcoin Jogando</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --o:#F7931A;--og:rgba(247,147,26,.12);--bg:#050505;--c1:#0C0C0C;--c2:#111;
  --bd:#1E1E1E;--t:#E8E8E8;--m:#555;--m2:#888;
  --gn:#22C55E;--rd:#EF4444;--yl:#EAB308;--bl:#3B82F6;--pu:#A855F7;
  --gold:#FFD700;
}
html,body{min-height:100vh;background:var(--bg);color:var(--t);font-family:system-ui,-apple-system,sans-serif;font-size:14px;overflow-x:hidden}

/* ANIMATIONS */
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes fadeIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
@keyframes slideUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:none}}
@keyframes glow{0%,100%{box-shadow:0 0 10px var(--o)}50%{box-shadow:0 0 30px var(--o),0 0 60px rgba(247,147,26,.3)}}
@keyframes shake{0%,100%{transform:translateX(0)}25%{transform:translateX(-6px)}75%{transform:translateX(6px)}}
@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
@keyframes confetti{0%{transform:translateY(-20px) rotate(0deg);opacity:1}100%{transform:translateY(100vh) rotate(720deg);opacity:0}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes goldShine{0%,100%{background-position:200% center}50%{background-position:-200% center}}
@keyframes typewriter{from{width:0}to{width:100%}}
@keyframes blockMine{0%{background:var(--c1)}50%{background:rgba(247,147,26,.15)}100%{background:rgba(34,197,94,.1)}}

.fade{animation:fadeIn .4s ease both}
.slide{animation:slideUp .5s ease both}
.float{animation:float 3s ease-in-out infinite}
.spin{animation:spin .8s linear infinite;display:inline-block}
.glow{animation:glow 2s ease-in-out infinite}
.bounce{animation:bounce .6s ease-in-out}

/* LAYOUT */
.app{max-width:800px;margin:0 auto;padding:0 12px 60px;min-height:100vh}

/* HEADER */
.game-header{background:linear-gradient(135deg,#0A0A0A,#111);border:1px solid var(--bd);border-radius:16px;padding:16px 20px;margin:14px 0 12px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px}
.game-logo{font-size:20px;font-weight:900;color:var(--o);letter-spacing:-.5px}
.game-sub{font-size:10px;color:var(--m);margin-top:2px}
.xp-bar-wrap{flex:1;max-width:260px}
.xp-label{display:flex;justify-content:space-between;font-size:10px;color:var(--m);margin-bottom:4px}
.xp-bar{height:6px;background:#1A1A1A;border-radius:6px;overflow:hidden}
.xp-fill{height:100%;background:linear-gradient(90deg,var(--o),#FFD700);border-radius:6px;transition:width .8s ease}
.level-badge{background:var(--og);border:1px solid rgba(247,147,26,.3);border-radius:10px;padding:4px 10px;font-size:11px;font-weight:700;color:var(--o)}

/* STAGE MAP */
.stage-map{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:14px;padding:12px 14px;background:var(--c1);border:1px solid var(--bd);border-radius:12px}
.stage-dot{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;cursor:pointer;transition:all .2s;border:2px solid transparent;flex-shrink:0;position:relative}
.stage-dot.done{background:rgba(34,197,94,.2);border-color:var(--gn);color:var(--gn)}
.stage-dot.active{background:rgba(247,147,26,.2);border-color:var(--o);color:var(--o);animation:glow 2s ease-in-out infinite}
.stage-dot.locked{background:#0A0A0A;border-color:#1A1A1A;color:#222;cursor:not-allowed}
.stage-dot.gold{background:rgba(255,215,0,.15);border-color:var(--gold);color:var(--gold);animation:glow 2s ease-in-out infinite}
.stage-line{flex:1;height:2px;background:#1A1A1A;align-self:center;min-width:8px}
.stage-line.done{background:var(--gn)}

/* CARDS */
.card{background:var(--c1);border:1px solid var(--bd);border-radius:12px;padding:16px 18px;margin-bottom:12px}
.card-title{font-size:15px;font-weight:800;margin-bottom:8px;display:flex;align-items:center;gap:8px}
.card-body{font-size:12px;color:var(--m2);line-height:1.8}
.highlight{background:rgba(247,147,26,.07);border-left:3px solid var(--o);border-radius:0 8px 8px 0;padding:10px 14px;font-size:12px;color:var(--t);line-height:1.7;margin:10px 0}

/* BUTTONS */
.btn{padding:10px 22px;border-radius:10px;font-size:13px;font-weight:800;border:none;background:var(--o);color:#000;cursor:pointer;font-family:inherit;transition:all .15s}
.btn:hover{opacity:.85;transform:translateY(-1px)}
.btn:active{transform:translateY(0)}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none}
.btn-s{padding:7px 16px;border-radius:8px;font-size:12px;font-weight:600;border:1px solid var(--bd);background:transparent;color:var(--m);cursor:pointer;font-family:inherit;transition:all .15s}
.btn-s:hover{border-color:var(--o);color:var(--o)}
.btn-gold{background:linear-gradient(135deg,#FFD700,#FFA500);color:#000;animation:glow 2s ease-in-out infinite}

/* QUIZ */
.quiz-opt{background:#080808;border:1px solid var(--bd);border-radius:9px;padding:11px 14px;cursor:pointer;font-size:12px;margin-bottom:7px;transition:all .15s;display:flex;align-items:center;gap:8px}
.quiz-opt:hover{border-color:rgba(247,147,26,.4);background:rgba(247,147,26,.04)}
.quiz-opt.correct{background:rgba(34,197,94,.1);border-color:var(--gn);color:var(--gn)}
.quiz-opt.wrong{background:rgba(239,68,68,.1);border-color:var(--rd);color:var(--rd);animation:shake .3s ease}
.quiz-opt.reveal{background:rgba(34,197,94,.06);border-color:rgba(34,197,94,.2)}
.opt-icon{width:22px;height:22px;border-radius:50%;border:1px solid var(--bd);display:flex;align-items:center;justify-content:center;font-size:10px;flex-shrink:0}

/* INTERACTIVE ELEMENTS */
.mine-btn{width:100%;padding:18px;font-size:24px;border-radius:12px;background:linear-gradient(135deg,rgba(247,147,26,.15),rgba(247,147,26,.05));border:2px solid rgba(247,147,26,.3);color:var(--o);cursor:pointer;font-family:inherit;transition:all .2s;font-weight:900;letter-spacing:1px}
.mine-btn:hover:not(:disabled){background:rgba(247,147,26,.2);transform:scale(1.02)}
.mine-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}

.hash-display{font-family:'Courier New',monospace;font-size:11px;background:#050505;border:1px solid var(--bd);border-radius:8px;padding:10px 12px;word-break:break-all;color:var(--m2);transition:color .3s;min-height:40px;line-height:1.6}
.hash-display.valid{color:var(--gn);border-color:rgba(34,197,94,.3)}

.block-visual{background:linear-gradient(135deg,rgba(247,147,26,.08),rgba(247,147,26,.02));border:2px solid rgba(247,147,26,.2);border-radius:12px;padding:14px 16px;font-family:'Courier New',monospace;font-size:11px;transition:all .5s}
.block-visual.mined{border-color:var(--gn);background:linear-gradient(135deg,rgba(34,197,94,.08),rgba(34,197,94,.02))}

.tx-item{background:#080808;border:1px solid var(--bd);border-radius:8px;padding:9px 12px;margin-bottom:6px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;transition:all .15s}
.tx-item:hover{border-color:rgba(247,147,26,.3)}
.tx-item.selected{border-color:var(--o);background:rgba(247,147,26,.06)}
.tx-item.confirmed{border-color:var(--gn);background:rgba(34,197,94,.06)}

.mempool-area{background:#050505;border:1px solid var(--bd);border-radius:10px;padding:12px;min-height:120px;position:relative;overflow:hidden}
.mempool-tx{display:inline-block;margin:3px;padding:4px 10px;border-radius:20px;font-size:10px;font-weight:700;cursor:pointer;transition:all .2s;animation:float 2s ease-in-out infinite}
.mempool-tx.high{background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);color:var(--rd)}
.mempool-tx.med{background:rgba(247,147,26,.15);border:1px solid rgba(247,147,26,.3);color:var(--o)}
.mempool-tx.low{background:rgba(34,197,94,.15);border:1px solid rgba(34,197,94,.3);color:var(--gn)}

.node-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:12px 0}
.node-item{background:#080808;border:1px solid var(--bd);border-radius:10px;padding:10px;text-align:center;transition:all .3s;cursor:default}
.node-item.validating{border-color:var(--o);background:rgba(247,147,26,.08);animation:pulse 1s ease-in-out infinite}
.node-item.valid{border-color:var(--gn);background:rgba(34,197,94,.08)}
.node-item.invalid{border-color:var(--rd);background:rgba(239,68,68,.08)}

.utxo-box{background:#080808;border:2px solid var(--bd);border-radius:10px;padding:10px 12px;display:flex;align-items:center;gap:8px;transition:all .3s;cursor:pointer}
.utxo-box.spent{opacity:.4;border-style:dashed;text-decoration:line-through}
.utxo-box.selected{border-color:var(--o);background:rgba(247,147,26,.08)}
.utxo-box.new{border-color:var(--gn);background:rgba(34,197,94,.08);animation:fadeIn .5s ease}

.addr-type{background:#080808;border:1px solid var(--bd);border-radius:10px;padding:12px 14px;margin-bottom:8px;cursor:pointer;transition:all .2s}
.addr-type:hover{border-color:rgba(247,147,26,.4)}
.addr-type.active{border-color:var(--o);background:var(--og)}
.addr-prefix{font-family:'Courier New',monospace;font-size:13px;font-weight:700;padding:2px 8px;border-radius:6px}

.wallet-card{background:#080808;border:1px solid var(--bd);border-radius:10px;padding:12px 14px;margin-bottom:8px;cursor:pointer;transition:all .2s;display:flex;align-items:flex-start;gap:10px}
.wallet-card:hover:not(.locked-w){border-color:rgba(247,147,26,.3)}
.wallet-card.selected-w{border-color:var(--o);background:var(--og)}
.wallet-card.locked-w{opacity:.5;cursor:not-allowed}
.wallet-card.danger-w{border-color:rgba(239,68,68,.3);background:rgba(239,68,34,.04)}

.sparrow-ui{background:#080808;border:1px solid var(--bd);border-radius:10px;padding:14px;font-family:system-ui;overflow:hidden}
.sparrow-tab{display:flex;gap:1px;background:#050505;border-radius:7px 7px 0 0;overflow:hidden;margin-bottom:0}
.sparrow-tab-btn{flex:1;padding:7px 4px;text-align:center;font-size:10px;font-weight:600;background:#0A0A0A;color:var(--m);cursor:pointer;border:none;font-family:inherit;transition:all .15s}
.sparrow-tab-btn.active{background:var(--c1);color:var(--o)}
.sparrow-body{background:var(--c1);border:1px solid var(--bd);border-radius:0 0 8px 8px;padding:12px}

.p2p-step{background:#080808;border:1px solid var(--bd);border-radius:10px;padding:12px 14px;margin-bottom:8px;display:flex;gap:10px;align-items:flex-start;transition:all .3s}
.p2p-step.active-step{border-color:var(--o);background:rgba(247,147,26,.06)}
.p2p-step.done-step{border-color:var(--gn);background:rgba(34,197,94,.06)}
.step-num{width:28px;height:28px;border-radius:50%;background:var(--bd);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;flex-shrink:0;transition:all .3s}
.step-num.active{background:var(--o);color:#000}
.step-num.done{background:var(--gn);color:#000}

/* PROGRESS & SCORE */
.score-popup{position:fixed;top:80px;right:20px;background:var(--o);color:#000;padding:8px 16px;border-radius:20px;font-size:13px;font-weight:800;z-index:1000;animation:slideUp .3s ease,fadeIn .3s ease;pointer-events:none}

.confetti-piece{position:fixed;width:8px;height:8px;border-radius:2px;pointer-events:none;z-index:999;animation:confetti 3s ease-in forwards}

.stage-complete{text-align:center;padding:24px;background:linear-gradient(135deg,rgba(34,197,94,.08),rgba(34,197,94,.02));border:1px solid rgba(34,197,94,.2);border-radius:14px;animation:fadeIn .5s ease}

/* GOLD STAGE */
.gold-card{background:linear-gradient(135deg,rgba(255,215,0,.08),rgba(255,165,0,.02));border:1px solid rgba(255,215,0,.25);border-radius:14px;padding:16px 18px;margin-bottom:12px}
.gold-title{font-size:16px;font-weight:900;background:linear-gradient(135deg,#FFD700,#FFA500);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}

/* CONFIRM ANIMATION */
.confirm-block{background:#080808;border:2px solid var(--bd);border-radius:8px;padding:10px;text-align:center;font-size:11px;transition:all .5s}
.confirm-block.confirmed{border-color:var(--gn);background:rgba(34,197,94,.08)}
.confirm-block.current{border-color:var(--o);background:rgba(247,147,26,.08);animation:glow 1s ease-in-out infinite}

/* MISC */
.tag{font-size:9px;padding:2px 7px;border-radius:10px;font-weight:600;display:inline-block}
.tag-green{background:rgba(34,197,94,.12);color:var(--gn)}
.tag-red{background:rgba(239,68,68,.12);color:var(--rd)}
.tag-orange{background:rgba(247,147,26,.12);color:var(--o)}
.tag-blue{background:rgba(59,130,246,.12);color:var(--bl)}
.tag-gold{background:rgba(255,215,0,.12);color:var(--gold)}

.progress-stages{display:flex;gap:6px;margin-bottom:6px;flex-wrap:wrap}
.ps{height:4px;flex:1;background:#1A1A1A;border-radius:4px;min-width:20px;transition:background .5s}
.ps.done{background:var(--gn)}
.ps.active{background:var(--o)}

input[type=range]{accent-color:var(--o);width:100%}
input[type=number],input[type=text]{background:#080808;border:1px solid var(--bd);border-radius:7px;padding:8px 11px;color:var(--t);font-size:13px;font-family:inherit;outline:none;transition:border-color .15s}
input:focus{border-color:var(--o)}

@media(max-width:600px){
  .node-grid{grid-template-columns:1fr 1fr}
  .stage-map{gap:3px}
  .stage-dot{width:24px;height:24px;font-size:10px}
}
</style>
</head>
<body>
<div class="app" id="app">

<div class="game-header fade">
  <div>
    <div class="game-logo">⛓ BAC Game</div>
    <div class="game-sub">Bitcoin Academy Club · Aprende jogando</div>
  </div>
  <div class="xp-bar-wrap">
    <div class="xp-label"><span>XP</span><span id="xp-text">0 / 1100</span></div>
    <div class="xp-bar"><div class="xp-fill" id="xp-fill" style="width:0%"></div></div>
  </div>
  <div class="level-badge" id="level-badge">Nível 1</div>
</div>

<!-- STAGE MAP -->
<div class="stage-map">
  <div class="stage-dot active" id="sd-0" onclick="jumpStage(0)" title="Blocos">⛓</div>
  <div class="stage-line" id="sl-0"></div>
  <div class="stage-dot locked" id="sd-1" onclick="jumpStage(1)" title="Transações">💸</div>
  <div class="stage-line" id="sl-1"></div>
  <div class="stage-dot locked" id="sd-2" onclick="jumpStage(2)" title="Mempool">🏊</div>
  <div class="stage-line" id="sl-2"></div>
  <div class="stage-dot locked" id="sd-3" onclick="jumpStage(3)" title="Nodes">🌐</div>
  <div class="stage-line" id="sl-3"></div>
  <div class="stage-dot locked" id="sd-4" onclick="jumpStage(4)" title="UTXO">🪙</div>
  <div class="stage-line" id="sl-4"></div>
  <div class="stage-dot locked" id="sd-5" onclick="jumpStage(5)" title="Confirmações">✅</div>
  <div class="stage-line" id="sl-5"></div>
  <div class="stage-dot locked" id="sd-6" onclick="jumpStage(6)" title="Endereços">📬</div>
  <div class="stage-line" id="sl-6"></div>
  <div class="stage-dot locked" id="sd-7" onclick="jumpStage(7)" title="Carteiras">🔐</div>
  <div class="stage-line" id="sl-7"></div>
  <div class="stage-dot locked" id="sd-8" onclick="jumpStage(8)" title="Assinaturas Criptográficas">✍</div>
  <div class="stage-line" id="sl-8"></div>
  <div class="stage-dot locked" id="sd-9" onclick="jumpStage(9)" title="Sparrow / Blue Wallet">💼</div>
  <div class="stage-line" id="sl-9"></div>
  <div class="stage-dot locked gold" id="sd-10" onclick="jumpStage(10)" title="P2P Gold">🥇</div>
</div>

<!-- STAGE CONTENT -->
<div id="stage-content"></div>

</div>

<script>
'use strict';

// ── STATE ─────────────────────────────────────────────────────────────────
let G = {
  stage: 0,
  xp: 0,
  maxXp: 1100,
  completed: new Set(),
  quizAnswered: new Set(),
  data: {}
};

const STAGE_XP = [100,100,100,100,100,100,100,100,100,100,200];

// ── UTILS ─────────────────────────────────────────────────────────────────
const $ = id => document.getElementById(id);
const randHex = n => [...Array(n)].map(()=>Math.floor(Math.random()*16).toString(16)).join('');
const sleep = ms => new Promise(r => setTimeout(r, ms));

function addXP(amount) {
  G.xp = Math.min(G.xp + amount, G.maxXp);
  const pct = (G.xp / G.maxXp * 100).toFixed(1);
  const fill = $('xp-fill');
  if(fill) fill.style.width = pct + '%';
  const txt = $('xp-text');
  if(txt) txt.textContent = `${G.xp} / ${G.maxXp}`;
  const lvl = Math.floor(G.xp / 100) + 1;
  const badge = $('level-badge');
  if(badge) badge.textContent = `Nível ${lvl}`;
  showScorePopup('+' + amount + ' XP');
}

function showScorePopup(txt) {
  const el = document.createElement('div');
  el.className = 'score-popup';
  el.textContent = txt;
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 2000);
}

function showConfetti() {
  const colors = ['#F7931A','#22C55E','#FFD700','#3B82F6','#A855F7'];
  for(let i=0;i<20;i++){
    const el=document.createElement('div');
    el.className='confetti-piece';
    el.style.cssText=`left:${Math.random()*100}vw;top:-20px;background:${colors[i%colors.length]};animation-delay:${Math.random()*.5}s;animation-duration:${2+Math.random()}s;transform:rotate(${Math.random()*360}deg)`;
    document.body.appendChild(el);
    setTimeout(()=>el.remove(),3000);
  }
}

function updateStageDots() {
  for(let i=0;i<=10;i++){
    const dot = $(`sd-${i}`);
    const line = $(`sl-${i}`);
    if(!dot) continue;
    if(G.completed.has(i)) {
      dot.className = i===10 ? 'stage-dot gold' : 'stage-dot done';
      dot.innerHTML = i===10 ? '🥇' : '✓';
    } else if(i === G.stage) {
      dot.className = i===10 ? 'stage-dot gold' : 'stage-dot active';
    } else if(i <= (G.completed.size)) {
      dot.className = 'stage-dot active';
      dot.style.opacity = '.6';
    }
    if(line && G.completed.has(i)) line.className = 'stage-line done';
  }
}

function jumpStage(n) {
  const unlocked = n === 0 || G.completed.has(n-1) || G.completed.has(n);
  if(!unlocked) return;
  G.stage = n;
  renderStage(n);
}

function completeStage() {
  G.completed.add(G.stage);
  addXP(STAGE_XP[G.stage]);
  showConfetti();
  updateStageDots();
  const next = G.stage + 1;
  if(next <= 10) {
    const dot = $(`sd-${next}`);
    if(dot) dot.className = next===10 ? 'stage-dot gold' : 'stage-dot active';
    setTimeout(() => {
      G.stage = next;
      renderStage(next);
    }, 2200);
  }
}

// ── QUIZ HELPER ───────────────────────────────────────────────────────────
function renderQuiz(containerId, questions, onAllCorrect) {
  const c = $(containerId); if(!c) return;
  let score = 0;
  const total = questions.length;

  c.innerHTML = questions.map((q,i) => `
    <div style="margin-bottom:14px" id="q-block-${i}">
      <div style="font-size:12px;font-weight:700;margin-bottom:8px;color:var(--t)">${q.q}</div>
      ${q.opts.map((o,j) => `
        <div class="quiz-opt" id="qo-${i}-${j}" onclick="answerQ(${i},${j},${q.a},${total},'${containerId}')">
          <div class="opt-icon">${'ABCD'[j]}</div>
          <span>${o}</span>
        </div>
      `).join('')}
    </div>
  `).join('');
  c._onAllCorrect = onAllCorrect;
  c._total = total;
  c._score = 0;
}

window.answerQ = function(qi, ji, correct, total, cid) {
  const opt = $(`qo-${qi}-${ji}`);
  if(!opt || opt.dataset.answered) return;
  const qKey = `${cid}-${qi}`;
  if(G.quizAnswered.has(qKey)) return;
  G.quizAnswered.add(qKey);
  // mark all opts for this question
  for(let k=0;k<4;k++){const o=$(`qo-${qi}-${k}`);if(o){o.dataset.answered='1';o.style.cursor='default';}}
  const isCorrect = ji === correct;
  opt.className = 'quiz-opt ' + (isCorrect ? 'correct' : 'wrong');
  $(`qo-${qi}-${correct}`)?.classList.add('correct');
  const c = $(cid);
  if(!c) return;
  if(isCorrect) {
    c._score = (c._score||0) + 1;
    addXP(10);
  }
  if(c._score === c._total && c._onAllCorrect) {
    setTimeout(() => c._onAllCorrect(), 600);
  }
};

// ── STAGE RENDERER ────────────────────────────────────────────────────────
function renderStage(n) {
  const stages = [s0,s1,s2,s3,s4,s5,s6,s7,s8,s9,s10];
  const c = $('stage-content');
  c.innerHTML = '';
  c.className = 'fade';
  stages[n]();
  window.scrollTo({top:0,behavior:'smooth'});
}

