  </div>
  `;

  const peachSteps = [
    {icon:'📲',title:'Descarrega Peach Bitcoin',desc:'Disponível na App Store e Google Play. Cria um nickname — não precisas de email, telefone ou identidade. O nickname é apenas para o sistema de reputação interno.'},
    {icon:'🔍',title:'Navega nas ofertas de venda',desc:'Vês uma lista de vendedores com reputação (estrelas + número de trades). Filtra por método de pagamento (MB Way, SEPA, Revolut, etc.) e valor.'},
    {icon:'🤝',title:'Aceita uma oferta',desc:'Seleccionas a oferta que queres. O Bitcoin do vendedor fica automaticamente bloqueado num escrow multisig 2-de-2. Ninguém pode mover os fundos sem ambas as partes concordarem.'},
    {icon:'💶',title:'Efectua o pagamento fiat',desc:'Envias o valor acordado por MB Way/Revolut/SEPA para o vendedor. Guarda sempre o comprovativo de pagamento.'},
    {icon:'✅',title:'Vendedor liberta os sats',desc:'Após confirmar o pagamento, o vendedor liberta o Bitcoin do escrow. Os sats chegam directamente à tua carteira — sem custódia, sem KYC.'},
    {icon:'📬',title:'Bitcoin na tua Sparrow Wallet',desc:'Os sats chegam com 0 confirmações. Aguardas 6 confirmações (~1h) e tens Bitcoin soberano — sem ligação à tua identidade, directamente na tua cold wallet airgap.'},
  ];

  G.data.peachStep = -1;
  const stepsEl = $('peach-steps');
  peachSteps.forEach((s,i) => {
    const el = document.createElement('div');
    el.className = 'p2p-step';
    el.id = `peach-step-${i}`;
    el.innerHTML = `<div class="step-num" id="peach-num-${i}">${i+1}</div><div><div style="font-size:12px;font-weight:700;margin-bottom:2px">${s.icon} ${s.title}</div><div style="font-size:11px;color:var(--m);display:none" id="peach-desc-${i}">${s.desc}</div></div>`;
