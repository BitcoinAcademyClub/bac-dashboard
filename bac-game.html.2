window.toggleMpTx = function(id, sats) {
  const sel = G.data.mpSel;
  const el = $(`mp-tx-${id}`);
  if(sel.has(id)) {
    sel.delete(id);
    el.style.transform = '';
    el.style.opacity = '1';
  } else {
    if(sel.size >= 4) return;
    sel.add(id);
    el.style.transform = 'scale(1.1)';
    el.style.opacity = '.7';
    el.style.filter = 'brightness(1.3)';
  }
  const totalFee = [...sel].reduce((s,id) => s + G.data.mpTxs.find(t=>t.id===id).sats, 0);
  const selEl = $('mp-sel'); if(selEl) selEl.textContent = sel.size;
  const feeEl = $('mp-fee'); if(feeEl) feeEl.textContent = totalFee.toLocaleString('pt-PT');
  const btn = $('mp-mine-btn'); if(btn) btn.disabled = sel.size === 0;
};

window.mineMempool = function() {
  const sel = G.data.mpSel;
  const txData = G.data.mpTxs;
  const selTxs = [...sel].map(id => txData.find(t=>t.id===id));
  const totalFee = selTxs.reduce((s,t)=>s+t.sats,0);
  const bestPossible = [...txData].sort((a,b)=>b.sats-a.sats).slice(0,4).reduce((s,t)=>s+t.sats,0);
  const efficiency = Math.round((totalFee/bestPossible)*100);
  const res = $('mp-result');
  if(res) {
    res.style.display='block';
    res.innerHTML=`<div style="background:rgba(247,147,26,.08);border:1px solid rgba(247,147,26,.2);border-radius:9px;padding:12px;font-size:11px">
      <div style="font-weight:700;color:var(--o);margin-bottom:6px">⛏ Bloco minerado com ${selTxs.length} transações!</div>
      <div>Fee total recolhido: <strong style="color:var(--gn)">${totalFee.toLocaleString('pt-PT')} sats</strong></div>
      <div>Eficiência: <strong style="color:${efficiency>80?'var(--gn)':'var(--yl)'}">${efficiency}%</strong> ${efficiency===100?'🏆 Perfeito!':efficiency>80?'👍 Muito bom!':'💡 Dica: selecciona os de maior sat/vB'}</div>
    </div>`;
    addXP(20);
  }
};

