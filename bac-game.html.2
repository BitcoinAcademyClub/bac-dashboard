window.startMining = async function() {
  if(G.data.blockMined) return;
  const btn = $('mine-btn');
  btn.disabled = true;
  btn.textContent = '⏳ A minerar...';
  const speed = parseInt($('speed-slider')?.value||1);
  const nonceEl = $('bk-nonce'), hashEl = $('hash-disp'), txsEl = $('bk-txs');
  const vis = $('block-vis');
  let nonce = 0;
  const interval = Math.max(10, 80 - speed*15);
  const target = Math.floor(10000 + Math.random()*40000);

  const mine = setInterval(() => {
    nonce += Math.floor(Math.random()*1000*speed)+100;
    if(nonceEl) nonceEl.textContent = nonce.toLocaleString('pt-PT');
    const fakeHash = randHex(64);
    if(hashEl) { hashEl.textContent = fakeHash; hashEl.className = 'hash-display'; }
    if(nonce >= target) {
      clearInterval(mine);
      const validHash = '00000' + randHex(59);
      if(hashEl) { hashEl.textContent = validHash; hashEl.className = 'hash-display valid'; }
      if(txsEl) txsEl.textContent = Math.floor(2000+Math.random()*700);
      if(vis) vis.className = 'block-visual mined';
      if(btn) { btn.textContent = '✅ Bloco Minerado!'; btn.style.background='rgba(34,197,94,.15)'; btn.style.borderColor='var(--gn)'; btn.style.color='var(--gn)'; }
      G.data.blockMined = true;
      addXP(30);
      const res = $('mine-result');
      if(res) {
        res.style.display = 'block';
        res.innerHTML = `<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px;padding:10px 14px;font-size:11px;color:var(--gn)">
          🎉 <strong>Bloco #880001 minerado!</strong> Nonce encontrado após ${nonce.toLocaleString('pt-PT')} tentativas. O hash começa com "00000" — cumpre a dificuldade da rede. Este bloco será propagado para todos os nodes Bitcoin em ~12 segundos.
        </div>`;
      }
    }
  }, interval);
};

