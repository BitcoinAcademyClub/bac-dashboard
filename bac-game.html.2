window.startConfirmations = async function() {
  const btn = $('conf-btn'); if(btn) btn.disabled=true;
  const statusEl = $('conf-status'), subEl = $('conf-sub');
  const blockHashes = [randHex(64),randHex(64),randHex(64),randHex(64),randHex(64),randHex(64)];
  for(let i=0;i<6;i++){
    await sleep(700);
    const cb = $(`cb-${i}`);
    if(cb) {
      cb.className = i === 5 ? 'confirm-block confirmed' : 'confirm-block confirmed';
      cb.innerHTML = `<div style="font-size:18px">🟩</div><div style="font-size:9px;color:var(--gn);margin-top:4px">${i===0?'Bloco TX':'Bloco '+(i+1)}</div><div style="font-size:9px;font-family:monospace;color:var(--m);margin-top:2px" id="cbs-${i}">${blockHashes[i].slice(0,8)}...</div>`;
    }
    if(statusEl) statusEl.textContent = `${i+1} Confirmação${i>0?'s':''} ✅`;
    if(subEl) subEl.textContent = i<5?`${5-i} confirmação(ões) em falta...`:'6 confirmações alcançadas!';
    addXP(5);
  }
  const res = $('conf-result');
  if(res) {
    res.style.display='block';
    res.innerHTML=`<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:9px;padding:12px;font-size:11px;color:var(--gn)">
      🔒 <strong>Transação consolidada com 6 confirmações!</strong> Esta transação está agora gravada permanentemente na blockchain Bitcoin e é considerada irreversível pela grande maioria da indústria. Bem-vindo à imutabilidade.
    </div>`;
  }
};

