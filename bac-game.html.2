window.toggleUtxo = function(id, btc) {
  const sel = G.data.utxoSel;
  const el = $(`ub-${id}`);
  if(sel.has(id)) {sel.delete(id);el.className='utxo-box';} 
  else {sel.add(id);el.className='utxo-box selected';}
  const total = [...sel].reduce((s,id)=>s+G.data.utxos.find(u=>u.id===id).btc,0);
  const sv = $('utxo-sel-val'); if(sv) sv.textContent = total.toFixed(8)+' BTC';
  const cv = $('utxo-change-val');
  if(total > 0.15) {
    const change = total - 0.15 - 0.0001;
    if(cv) cv.textContent = (change>0?change:0).toFixed(8)+' BTC';
  } else {
    if(cv) cv.textContent = total>=0.15?'0.00000000 BTC':'Insuficiente';
  }
  const btn = $('utxo-send-btn'); if(btn) btn.disabled = total < 0.15;
};

window.sendUtxo = function() {
  const sel = G.data.utxoSel;
  const total = [...sel].reduce((s,id)=>s+G.data.utxos.find(u=>u.id===id).btc,0);
  const change = +(total - 0.15 - 0.0001).toFixed(8);
  sel.forEach(id => {const el=$(`ub-${id}`);if(el)el.className='utxo-box spent';});
  const res = $('utxo-result');
  if(res) {
    res.style.display='block';
    res.innerHTML=`<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:9px;padding:12px;font-size:11px">
      <div style="color:var(--gn);font-weight:700;margin-bottom:6px">✅ Transação Construída!</div>
      <div>Inputs gastos: <strong>${sel.size} UTXO(s)</strong> totalizando ${total.toFixed(8)} BTC</div>
      <div>Output principal: <strong>0.15000000 BTC</strong> → destinatário</div>
      ${change>0?`<div>Output troco: <strong style="color:var(--bl)">${change} BTC</strong> → de volta para a tua carteira</div>`:''}
      <div>Fee: <strong style="color:var(--o)">0.00010000 BTC</strong> → miner</div>
    </div>`;
    addXP(20);
  }
};

