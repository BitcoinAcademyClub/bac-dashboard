      <span style="color:var(--m)">Fee:</span><span style="color:var(--o)">${feeSats.toLocaleString('pt-PT')} sats ≈ €${feeEur}</span>
      <span style="color:var(--m)">Tamanho:</span><span>${size} vBytes</span>
      <span style="color:var(--m)">Confirmação:</span><span style="color:${fee>20?'var(--gn)':fee>8?'var(--o)':'var(--rd)'}">${conf}</span>
