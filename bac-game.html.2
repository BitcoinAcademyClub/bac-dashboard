  const body = $('sparrow-body');
  if(!body) return;
  if(tab==='recv') {
    body.innerHTML=`<div style="text-align:center">
      <div style="font-size:11px;color:var(--m);margin-bottom:8px">Endereço de recepção (bc1q... — Native SegWit)</div>
      <div style="background:#050505;border:1px solid var(--bd);border-radius:8px;padding:14px;display:inline-block;margin-bottom:8px">
        <div style="display:grid;grid-template-columns:repeat(8,16px);gap:2px">
          ${[...Array(64)].map((_,i)=>`<div style="width:16px;height:16px;background:${Math.random()>.5?'var(--t)':'var(--bg)'}"></div>`).join('')}
        </div>
      </div>
      <div style="font-family:monospace;font-size:10px;color:var(--o);word-break:break-all;max-width:300px;margin:0 auto 8px">bc1q7cy8k2u9pq5n3m4w1xz9v6ertf8ghj2lk...</div>
      <div style="font-size:10px;color:var(--m)">Cada recepção usa um endereço novo — privacidade garantida</div>
      <div style="margin-top:10px"><button class="btn" onclick="simulateReceive()" id="recv-btn">Simular Recepção de 0.05 BTC</button></div>
      <div id="recv-result" style="margin-top:8px"></div>
    </div>`;
  } else if(tab==='send') {
    body.innerHTML=`<div>
      <div style="font-size:11px;color:var(--m);margin-bottom:8px">Enviar Bitcoin</div>
      <div style="margin-bottom:8px"><div style="font-size:10px;color:var(--m);margin-bottom:3px">Endereço de destino</div>
      <input type="text" placeholder="bc1q... ou 1... ou 3..." style="width:100%;font-size:11px"></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px">
        <div><div style="font-size:10px;color:var(--m);margin-bottom:3px">Valor (BTC)</div><input type="number" placeholder="0.01000000" step="0.001"></div>
        <div><div style="font-size:10px;color:var(--m);margin-bottom:3px">Fee (sat/vB)</div><input type="number" placeholder="12" min="1" max="100"></div>
      </div>
      <div style="font-size:10px;color:var(--m);margin-bottom:8px">⚠ A Sparrow irá gerar uma PSBT para assinares com o teu dispositivo airgap</div>
      <button class="btn" onclick="simulateSend()">Criar PSBT para Assinar</button>
      <div id="send-result" style="margin-top:8px"></div>
    </div>`;
  } else if(tab==='txs') {
    const txs=[{hash:randHex(8),type:'Recebido',amount:'+0.05000000',conf:'142',date:'15 Mar 2026'},{hash:randHex(8),type:'Enviado',amount:'-0.02000000',conf:'89',date:'10 Mar 2026'},{hash:randHex(8),type:'Recebido',amount:'+0.10000000',conf:'312',date:'1 Mar 2026'}];
    body.innerHTML=`<div style="font-size:11px;color:var(--m);margin-bottom:8px">Historial de Transações</div>${txs.map(t=>`<div style="display:flex;justify-content:space-between;align-items:center;padding:8px;background:#050505;border-radius:6px;margin-bottom:5px;font-size:11px"><div><div style="font-weight:600;color:${t.type==='Recebido'?'var(--gn)':'var(--rd)'}">${t.type}</div><div style="font-family:monospace;font-size:9px;color:var(--m)">${t.hash}... · ${t.conf} conf.</div></div><div style="text-align:right"><div style="font-weight:700;color:${t.type==='Recebido'?'var(--gn)':'var(--rd)'}">${t.amount} BTC</div><div style="font-size:9px;color:var(--m)">${t.date}</div></div></div>`).join('')}`;
  } else if(tab==='utxo') {
    body.innerHTML=`<div style="font-size:11px;color:var(--m);margin-bottom:8px">UTXOs disponíveis (Coin Control)</div>
    <div style="font-size:10px;color:rgba(247,147,26,.7);margin-bottom:8px">💡 Na Sparrow, podes etiquetar cada UTXO para saber a sua origem — fundamental para privacidade</div>
    ${[{amt:'0.05',label:'Recebido P2P Peach',date:'15 Mar'},{amt:'0.10',label:'Recebido P2P RoboSats',date:'1 Mar'},{amt:'0.03',label:'Troco tx anterior',date:'10 Mar'}].map(u=>`<div style="display:flex;justify-content:space-between;align-items:center;background:#050505;border:1px solid var(--bd);border-radius:7px;padding:8px 10px;margin-bottom:5px;font-size:11px"><div><div style="font-weight:600;color:var(--o)">${u.amt} BTC</div><div style="font-size:9px;color:var(--gn)">${u.label}</div></div><div style="font-size:9px;color:var(--m)">${u.date}</div></div>`).join('')}`;
  }
};

window.simulateReceive = function() {
  const btn = $('recv-btn'); if(btn) btn.disabled=true;
  setTimeout(() => {
    const res = $('recv-result');
    if(res) res.innerHTML=`<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:7px;padding:8px 10px;font-size:11px;color:var(--gn)">✅ 0.05 BTC recebidos! Aguarda 6 confirmações para usar.</div>`;
    addXP(15);
  }, 1000);
};

window.simulateSend = function() {
  const res = $('send-result');
  setTimeout(() => {
    if(res) res.innerHTML=`<div style="background:rgba(247,147,26,.08);border:1px solid rgba(247,147,26,.2);border-radius:7px;padding:8px 10px;font-size:11px;color:var(--o)">✅ PSBT gerada! Exporta para a tua Assinatura Criptográfica (Coldcard/SeedSigner) para assinar.</div>`;
    addXP(15);
  }, 800);
};

// ══════════════════════════════════════════════════════════════════
// STAGE 10: P2P GOLD 🥇
// ══════════════════════════════════════════════════════════════════
function s10() {
  const c = $('stage-content');
  c.innerHTML = `
  <div class="gold-card slide">
    <div class="gold-title">🥇 Etapa OURO — Compra P2P sem KYC</div>
    <div style="font-size:12px;color:var(--m2);line-height:1.8;margin-top:8px">
      Chegaste ao estágio final — e o mais importante para a soberania financeira completa. A única forma de adquirir Bitcoin sem ligar a tua identidade aos teus UTXOs é através de <strong style="color:var(--o)">trocas P2P (peer-to-peer)</strong>.
