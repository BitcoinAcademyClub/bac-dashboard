let peachStepC = 0;
window.advancePeach = async function() {
  const steps = 6;
  const btn = G.data.peachNextBtn;
  if(peachStepC >= steps) return;
  if(btn) { btn.disabled=true; btn.textContent='⏳ Em progresso...'; }
  await sleep(500);
  const stepEl = $(`peach-step-${peachStepC}`);
  const numEl = $(`peach-num-${peachStepC}`);
  const descEl = $(`peach-desc-${peachStepC}`);
  if(stepEl) stepEl.className='p2p-step done-step';
  if(numEl) { numEl.className='step-num done'; numEl.textContent='✓'; }
  if(descEl) descEl.style.display='block';
  addXP(10);
  peachStepC++;
  if(peachStepC < steps) {
    const next = $(`peach-step-${peachStepC}`);
    const nextNum = $(`peach-num-${peachStepC}`);
    if(next) next.className='p2p-step active-step';
    if(nextNum) nextNum.className='step-num active';
    if(btn) { btn.disabled=false; btn.textContent=`▶ Passo ${peachStepC+1}: ${['Descarregar App','Navegar Ofertas','Aceitar Oferta','Pagar Fiat','Aguardar Release','Confirmar'][peachStepC]}`; }
  } else {
    if(btn) { btn.disabled=true; btn.textContent='🍑 Compra P2P Completa!'; btn.style.background='rgba(247,147,26,.15)'; btn.style.color='var(--o)'; }
    const res = $('peach-result');
    if(res) {
      res.style.display='block';
      res.innerHTML=`<div style="background:rgba(255,215,0,.08);border:1px solid rgba(255,215,0,.25);border-radius:9px;padding:12px;font-size:11px;color:var(--gold)">
        🥇 <strong>Compra P2P sem KYC concluída!</strong> O teu Bitcoin chegou directamente à Sparrow Wallet — sem exchange, sem identidade ligada, sem custódia de terceiros. Isto é soberania financeira Bitcoin.
      </div>`;
    }
  }
};
peachStepC = 0;

// ── INIT ──────────────────────────────────────────────────────────────────
renderStage(0);
</script>
