let psbtStepCurrent = 0;
window.advancePsbt = async function() {
  const steps = 6;
  if(psbtStepCurrent >= steps) return;
  const btn = G.data.psbtAdvBtn;
  if(btn) { btn.disabled=true; btn.textContent='⏳ A executar...'; }
  await sleep(600);
  const stepEl = $(`ps-step-${psbtStepCurrent}`);
  const numEl = $(`ps-num-${psbtStepCurrent}`);
  const descEl = $(`ps-desc-${psbtStepCurrent}`);
  if(stepEl) stepEl.className='p2p-step done-step';
  if(numEl) { numEl.className='step-num done'; numEl.textContent='✓'; }
  if(descEl) descEl.style.display='block';
  addXP(10);
  psbtStepCurrent++;
  if(psbtStepCurrent < steps) {
    const next = $(`ps-step-${psbtStepCurrent}`);
    const nextNum = $(`ps-num-${psbtStepCurrent}`);
    if(next) next.className='p2p-step active-step';
    if(nextNum) { nextNum.className='step-num active'; }
    if(btn) { btn.disabled=false; btn.textContent=`▶ Executar Passo ${psbtStepCurrent+1}`; }
  } else {
    if(btn) { btn.disabled=true; btn.textContent='✅ Fluxo Completo!'; btn.style.background='rgba(34,197,94,.15)'; btn.style.color='var(--gn)'; btn.style.border='1px solid var(--gn)'; }
    const res = $('psbt-result');
    if(res) {
      res.style.display='block';
      res.innerHTML=`<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:9px;padding:12px;font-size:11px;color:var(--gn)">
        🔒 <strong>Fluxo airgap completo!</strong> A transação foi assinada com a Coldcard/SeedSigner completamente offline e transmitida pela Sparrow. As tuas chaves privadas nunca saíram do dispositivo airgap. Esta é a soberania máxima no Bitcoin.
      </div>`;
    }
  }
};
psbtStepCurrent = 0;

