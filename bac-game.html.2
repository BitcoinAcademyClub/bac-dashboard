window.validateNode = async function(id) {
  const el = $(`ni-${id}`); const st = $(`nst-${id}`);
  if(!el || G.data.nodesValidated.has(id)) return;
  el.className = 'node-item validating';
  if(st) st.textContent = 'A validar...';
  await sleep(800 + Math.random()*600);
  el.className = 'node-item valid';
  if(st) { st.textContent = '✅ Válido'; st.style.color='var(--gn)'; }
  G.data.nodesValidated.add(id);
  addXP(5);
  const statusEl = $('node-status');
  if(statusEl) statusEl.textContent = `${G.data.nodesValidated.size}/6 nodes validaram o bloco`;
  if(G.data.nodesValidated.size === 6) {
    const res = $('node-result');
    if(res) {
      res.style.display='block';
      res.innerHTML=`<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px;padding:10px 14px;font-size:11px;color:var(--gn)">
        🌐 <strong>Consenso alcançado!</strong> Todos os 6 nodes concordam que o bloco é válido. Em ~12 segundos, este bloco foi propagado para os 15.000+ nodes da rede Bitcoin worldwide.
      </div>`;
    }
  }
};

