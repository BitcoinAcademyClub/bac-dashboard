  const size = 250;
  const feeSats = fee * size;
  const feeBtc = feeSats / 1e8;
  const change = 0.50 - 0.20 - feeBtc;
  const feeEur = (feeBtc * 75000).toFixed(2);
  const conf = fee > 20 ? '~10 min (próximo bloco)' : fee > 8 ? '~30 min (~3 blocos)' : '~1-3 horas (+6 blocos)';
  const calc = $('tx-calc');
  if(calc) calc.innerHTML = `
    <div style="display:grid;grid-template-columns:auto 1fr;gap:4px 12px;align-items:center">
      <span style="color:var(--m)">Input:</span><span style="color:var(--rd)">0.50000000 BTC</span>
